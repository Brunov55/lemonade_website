---
import Layout from "../layouts/Layout.astro";
import ProductButton from "../components/ProductButton.astro";
import BottomNav from "../components/BottomNav.astro";
import { salesService } from "../services/salesService";

import caracalImg from "../assets/caracal.jpeg";

// REGLA #3: Carga Inicial SSR (Pidiendo ventas desde el servidor inyectando la cookie)
const cookieHeader = Astro.request.headers.get("cookie");
let totalVentas = await salesService.getTodaySalesTotal(cookieHeader);

// Obtener TODAS las ventas recientes (limit alto) y filtrar "sólo las de hoy" en la zona de México
const ventasRecientes = await salesService.getRecentSales(cookieHeader, 1000);
const MX_TZ = 'America/Mexico_City';
const hoy = new Date().toLocaleDateString('es-MX', { timeZone: MX_TZ });
const ventasHoy = ventasRecientes.filter(
  (v) => v.date.toLocaleDateString('es-MX', { timeZone: MX_TZ }) === hoy
);

// Parche de Seguridad: Si por problema de Zonas Horarias el endpoint /today devuelve 0
// pero la lista de transacciones SÍ tiene ventas de hoy, calculamos el total sumando la lista.
if (totalVentas === 0 && ventasHoy.length > 0) {
	totalVentas = ventasHoy.reduce((acc, venta) => acc + (venta.price || 0), 0);
}
---

<Layout title="Dashboard - Caracal Lemonade">
	<header
		class="bg-primary pt-12 pb-6 px-6 border-b-[3px] border-theme-border neo-shadow text-center sticky top-0 z-40"
	>
		<p
			class="text-pop-white font-bold text-sm uppercase tracking-widest mb-1 opacity-90"
		>
			Ventas de Hoy
		</p>
		<h1
			class="text-5xl font-display font-bold text-pop-white transition-all duration-300"
			id="total-ventas-display"
		>
			<span class="text-2xl align-top mr-1">$</span><span id="total-monto"
				>{totalVentas.toFixed(2)}</span
			>
		</h1>
	</header>

	<main class="flex-1 px-4 py-8 pb-24">
		<!-- PRUEBA DE ZONA HORARIA -->
		<div class="mb-6 bg-theme-surface p-4 neo-border neo-shadow text-center">
			<p class="text-xs font-bold text-theme-muted mb-2 uppercase">Hora Servidor (SSR): <span class="text-accent">{new Date().toLocaleString('es-MX', { timeZone: 'America/Mexico_City' })}</span></p>
			<button id="test-time-btn" class="w-full bg-theme-border text-theme-surface font-display font-bold uppercase tracking-widest text-sm py-2 neo-border active:translate-y-1 transition-transform">
				Probar Hora Cliente
			</button>
		</div>

		<h2
			class="text-xl font-display uppercase tracking-tight font-bold mb-4 px-2 text-theme-text"
		>
			Venta Rápida
		</h2>

		<div class="grid grid-cols-2 gap-4 mb-8">
			<ProductButton
				title="Natural"
				subtitle="500ml"
				price={25}
				imageSrc={caracalImg}
			/>
			<ProductButton
				title="Mineral"
				subtitle="500ml"
				price={35}
				imageSrc={caracalImg}
			/>
			<ProductButton
				title="Natural"
				subtitle="1 Litro"
				price={45}
				imageSrc={caracalImg}
			/>
			<ProductButton
				title="Mineral"
				subtitle="1 Litro"
				price={65}
				imageSrc={caracalImg}
			/>
		</div>

		<section>
			<div class="flex justify-between items-center mb-4 px-2">
				<h2
					class="text-xl font-display uppercase tracking-tight font-bold text-theme-text"
				>
					Registro de Hoy
				</h2>
				<span
					class="text-xs font-bold text-theme-surface bg-theme-border px-2 py-1 border-2 border-theme-border shadow-[2px_2px_0px_0px_var(--color-theme-border)]"
					id="ventas-count">{ventasHoy.length} items</span
				>
			</div>

			<div class="flex flex-col gap-3" id="ventas-list">
				{
					ventasHoy.length > 0 ? (
						ventasHoy.map((venta: any) => {
							const isMineral = (
								venta.product ||
								venta.productName ||
								""
							)
								.toLowerCase()
								.includes("mineral");
							return (
								<div class="bg-theme-surface p-4 neo-border neo-shadow flex justify-between items-center transition-all group">
									<div class="flex items-center gap-3">
										<div class="w-10 h-10 border-[3px] border-theme-border flex items-center justify-center font-bold bg-primary text-theme-border">
											{isMineral ? (
												<svg
													class="w-5 h-5"
													fill="none"
													stroke="currentColor"
													viewBox="0 0 24 24"
												>
													<path
														stroke-linecap="round"
														stroke-linejoin="round"
														stroke-width="2"
														d="M10 2v3a1 1 0 001 1h2a1 1 0 001-1V2M9 6h6l1.5 3v11a2 2 0 01-2 2H9.5a2 2 0 01-2-2V9L9 6z"
													/>
												</svg>
											) : (
												<svg
													class="w-5 h-5"
													fill="none"
													stroke="currentColor"
													viewBox="0 0 24 24"
												>
													<path
														stroke-linecap="round"
														stroke-linejoin="round"
														stroke-width="2"
														d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"
													/>
												</svg>
											)}
										</div>
										<div>
											<p class="font-display font-bold text-sm text-theme-text">
												$
												{venta.product ||
													venta.productName ||
													"Venta"}
											</p>
											<p class="text-xs font-bold text-theme-muted uppercase">
												Hoy •{" "}
												{venta.date.toLocaleTimeString(
													'es-MX',
													{
														hour: "2-digit",
														minute: "2-digit",
														timeZone: "America/Mexico_City"
													},
												)}
											</p>
										</div>
									</div>
									<p class="font-bold text-accent">
										+${venta.price.toFixed(2)}
									</p>
								</div>
							);
						})
					) : (
						<p
							id="empty-state"
							class="text-center text-sm text-theme-muted py-6 bg-theme-surface rounded-2xl border border-dashed border-theme-border"
						>
							Aún no hay ventas registradas hoy.
						</p>
					)
				}
			</div>
		</section>
	</main>

	<BottomNav />
</Layout>

<script>
	import { apiClient } from "../utils/apiClient";

	const totalMontoEl = document.getElementById("total-monto");
	const headerTextEl = document.getElementById("total-ventas-display");
	const ventasListEl = document.getElementById("ventas-list");
	const countEl = document.getElementById("ventas-count");
	const buttons = document.querySelectorAll(".btn-venta");

	// Prisma de prueba de hora y UI Optimista
	const testTimeBtn = document.getElementById("test-time-btn");
	if (testTimeBtn) {
		testTimeBtn.addEventListener("click", () => {
			const browserTime = new Date().toLocaleString('es-MX', { timeZone: 'America/Mexico_City' });
			const rawTime = new Date().toLocaleString(); // Browser's actual local time
			
			// 1. Mostrar transacción visual
			const emptyState = document.getElementById("empty-state");
			if (emptyState) emptyState.remove();

			if (countEl) {
				const currentCount = parseInt(countEl.innerText.split(" ")[0]);
				countEl.innerText = `${currentCount + 1} items`;
			}

			const now = new Date();
			const timeString = now.toLocaleTimeString('es-MX', {
				hour: "2-digit",
				minute: "2-digit",
				timeZone: "America/Mexico_City"
			});

			const newItem = document.createElement("div");
			newItem.className =
				"bg-theme-surface p-4 neo-border neo-shadow flex justify-between items-center transition-all opacity-0 -translate-y-4 border-theme-border";
			newItem.innerHTML = `
				<div class="flex items-center gap-3">
					<div class="w-10 h-10 border-[3px] border-theme-border flex items-center justify-center font-bold bg-primary text-theme-border">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"></path>
						</svg>
					</div>
					<div>
						<p class="font-display font-bold text-sm text-accent">PRUEBA DE HORA</p>
						<p class="text-xs font-bold text-theme-muted uppercase">Hoy • ${timeString}</p>
					</div>
				</div>
				<div class="flex items-center gap-3">
					<p class="font-bold text-accent">+$0.00</p>
					<button class="delete-dummy-btn text-red-500 bg-red-100 border-2 border-red-500 p-1 neo-shadow active:translate-y-1 transition-all">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
						</svg>
					</button>
				</div>
			`;

			const deleteBtn = newItem.querySelector('.delete-dummy-btn');
			if (deleteBtn) {
				deleteBtn.addEventListener('click', () => {
					// Animación de salida antes de remover
					newItem.classList.remove("opacity-100", "translate-y-0");
					newItem.classList.add("opacity-0", "-translate-y-4");
					setTimeout(() => {
						newItem.remove();
						if (countEl) {
							const currentCount = parseInt(countEl.innerText.split(" ")[0]);
							countEl.innerText = `${Math.max(0, currentCount - 1)} items`;
						}
					}, 300); // 300ms debe coincidir con la duración de 'transition-all'
				});
			}

			if (ventasListEl) {
				ventasListEl.prepend(newItem);
				requestAnimationFrame(() => {
					newItem.classList.remove("opacity-0", "-translate-y-4");
					newItem.classList.add("opacity-100", "translate-y-0");
				});
			}

			alert(`Se generó una venta de prueba visual.\n\nHora calculada (MX): ${browserTime}\nHora interna del dispositivo: ${rawTime}`);
		});
	}

	// SVG Paths for optimistic UI
	const getIconPath = (product: string) => {
		const isMin = product.toLowerCase().includes("mineral");
		return isMin
			? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 2v3a1 1 0 001 1h2a1 1 0 001-1V2M9 6h6l1.5 3v11a2 2 0 01-2 2H9.5a2 2 0 01-2-2V9L9 6z"></path>'
			: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"></path>';
	};

	const getIconColorClass = () => {
		return "bg-ocean-50 text-ocean-600 dark:bg-ocean-800 dark:text-ocean-300";
	};

	buttons.forEach((btn) => {
		let holdTimeout: ReturnType<typeof setTimeout> | undefined;
		const HOLD_DURATION = 500; // ms
		let isHolding = false;

		const startHold = (e: Event) => {
			if (e.type === 'touchstart') {
				isHolding = true;
			} else if (e.type === 'mousedown' && isHolding) {
				return; // Si ya se manejó por touchstart, ignorar mousedown
			}

			const btnEl = e.currentTarget as HTMLButtonElement;
			const progressBar = btnEl.querySelector(".progress-bar") as HTMLElement;
			
			if (progressBar) {
				progressBar.style.transitionDuration = `${HOLD_DURATION}ms`;
				progressBar.style.height = '100%';
			}

			if (navigator.vibrate) navigator.vibrate(15); // Feedback táctil inicial

			holdTimeout = setTimeout(() => executeSale(btnEl), HOLD_DURATION);
		};

		const cancelHold = (e: Event) => {
			const btnEl = e.currentTarget as HTMLButtonElement;
			const progressBar = btnEl.querySelector(".progress-bar") as HTMLElement;
			
			if (progressBar) {
				progressBar.style.transitionDuration = '150ms';
				progressBar.style.height = '0%';
			}

			if (holdTimeout) {
				clearTimeout(holdTimeout);
				holdTimeout = undefined;
			}
			
			if (e.type === 'touchend' || e.type === 'touchcancel') {
				setTimeout(() => { isHolding = false; }, 300);
			}
		};

		// Eventos Touch y Mouse acoplados
		btn.addEventListener("mousedown", startHold);
		btn.addEventListener("touchstart", startHold, { passive: true });
		
		btn.addEventListener("mouseup", cancelHold);
		btn.addEventListener("mouseleave", cancelHold);
		btn.addEventListener("touchend", cancelHold);
		btn.addEventListener("touchcancel", cancelHold);
		
		// Prevenir el menú contextual en móviles al dejar presionado
		btn.addEventListener("contextmenu", (e) => { 
			e.preventDefault(); 
			cancelHold(e); 
		});

		const executeSale = async (btnEl: HTMLButtonElement) => {
			// Reiniciar progreso visual instantáneo para el siguiente toque
			const progressBar = btnEl.querySelector(".progress-bar") as HTMLElement;
			if (progressBar) {
				progressBar.style.transitionDuration = '0ms';
				progressBar.style.height = '0%';
			}
			holdTimeout = undefined;

			// Tacto de éxito para confirmar al usuario físicamente
			if (navigator.vibrate) navigator.vibrate([30, 50, 30]);

			const product = btnEl.dataset.product || "Venta";
			const price = parseFloat(btnEl.dataset.price || "0");

			if (!totalMontoEl || !headerTextEl) return;

			// 1. REGLA #3: UI Optimista (Velocidad para la calle)
			const currentTotal = parseFloat(totalMontoEl.innerText);
			const newTotal = currentTotal + price;

			// Actualizamos el Header
			totalMontoEl.innerText = newTotal.toFixed(2);
			headerTextEl.classList.add("text-accent", "scale-110");
			setTimeout(
				() => headerTextEl.classList.remove("text-accent", "scale-110"),
				300,
			);

			// Actualizamos la Lista de Transacciones "Optimistamente"
			const emptyState = document.getElementById("empty-state");
			if (emptyState) emptyState.remove();

			if (countEl) {
				const currentCount = parseInt(countEl.innerText.split(" ")[0]);
				countEl.innerText = `${currentCount + 1} items`;
			}

			const now = new Date();
			const timeString = now.toLocaleTimeString('es-MX', {
				hour: "2-digit",
				minute: "2-digit",
				timeZone: "America/Mexico_City"
			});

			const newItem = document.createElement("div");
			newItem.className =
				"bg-theme-surface p-4 neo-border neo-shadow flex justify-between items-center transition-all opacity-0 -translate-y-4";
			newItem.innerHTML = `
				<div class="flex items-center gap-3">
					<div class="w-10 h-10 border-[3px] border-theme-border flex items-center justify-center font-bold bg-primary text-theme-border">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							${getIconPath(product)}
						</svg>
					</div>
					<div>
						<p class="font-display font-bold text-sm text-theme-text">${product}</p>
						<p class="text-xs font-bold text-theme-muted uppercase">Hoy • ${timeString}</p>
					</div>
				</div>
				<p class="font-bold text-accent">+$${price.toFixed(2)}</p>
			`;

			if (ventasListEl) {
				ventasListEl.prepend(newItem);
				// Animación de entrada suave
				requestAnimationFrame(() => {
					newItem.classList.remove("opacity-0", "-translate-y-4");
					newItem.classList.add("opacity-100", "translate-y-0");
				});
			}

			// 2. Trabajo Sucio: Fetch POST en Background
			try {
				await apiClient("/sales", {
					method: "POST",
					body: JSON.stringify({ product, price }),
				});
				// Tras el éxito, aseguramos la clase de borde final
				setTimeout(() => {
					newItem.classList.add("border-theme-border");
				}, 1000);
			} catch (error) {
				// 3. Rollback (Regla #4: Manejo de Errores)
				totalMontoEl.innerText = currentTotal.toFixed(2);
				headerTextEl.classList.add("text-red-500");
				setTimeout(
					() => headerTextEl.classList.remove("text-red-500"),
					500,
				);

				// Revertir la lista
				newItem.remove();
				if (countEl) {
					countEl.innerText = `${parseInt(countEl.innerText.split(" ")[0]) - 1} items`;
				}

				alert(`Venta fallida: ${(error as Error).message}`);
			}
		};
	});
</script>
