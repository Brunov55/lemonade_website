---
import Layout from "../layouts/Layout.astro";

const isLoggedOut = Astro.url.searchParams.get("logout") === "true";
---

<Layout title="Entrar — Acid Berry Lab POS">
	<main
		class="flex flex-col justify-center items-center min-h-screen px-6 font-body"
		style="background: var(--color-theme-bg);"
	>
		<div
			class="w-full max-w-sm px-7 py-10"
			style="background: var(--color-theme-surface); border-radius: 8px; border: 3px solid var(--color-theme-border); box-shadow: 6px 6px 0px var(--color-theme-border);"
		>
			<!-- Logo / Brand -->
			<div class="text-center mb-8">
				<div
					class="w-16 h-16 flex items-center justify-center text-3xl mx-auto mb-4"
					style="background: var(--color-theme-surface); border: 3px solid var(--color-theme-border); box-shadow: 4px 4px 0px var(--color-theme-border); border-radius: 8px;"
				>
					🍋
				</div>
				<p
					class="text-[11px] font-bold tracking-[0.2em] uppercase mb-1"
					style="color: var(--color-primary);"
				>
					Acid Berry Lab
				</p>
				<h1
					class="font-display text-2xl font-bold"
					style="color: var(--color-theme-text);"
				>
					Bienvenido
				</h1>
				<p
					class="text-sm mt-1"
					style="color: var(--color-theme-muted, #7A5C4A);"
				>
					Ingresa para operar el punto de venta
				</p>
			</div>

			<!-- Gold divider -->
			<div class="divider-gold mb-6"></div>

			{
				isLoggedOut && (
					<div
						class="text-center text-sm font-medium px-3 py-2 rounded-xl mb-4"
						style="background: color-mix(in srgb, #5A8A5A 10%, transparent); color: #3A6A3A; border: 1px solid color-mix(in srgb, #5A8A5A 30%, transparent);"
					>
						✓ Sesión cerrada correctamente.
					</div>
				)
			}

			<form id="login-form" class="flex flex-col gap-4">
				<div>
					<label
						class="block text-xs font-semibold uppercase tracking-wide mb-1.5"
						style="color: var(--color-theme-muted);"
					>
						Usuario
					</label>
					<input
						type="text"
						id="username"
						placeholder="Tu usuario"
						required
						class="w-full text-sm p-3 outline-none transition-all duration-200"
						style="background: #FFFFFF; border: 3px solid var(--color-theme-border); box-shadow: 3px 3px 0px var(--color-theme-border); border-radius: 4px; color: var(--color-theme-text);"
					/>
				</div>
				<div>
					<label
						class="block text-xs font-semibold uppercase tracking-wide mb-1.5"
						style="color: var(--color-theme-muted);"
					>
						Contraseña
					</label>
					<input
						type="password"
						id="password"
						placeholder="••••••••"
						required
						class="w-full text-sm p-3 outline-none transition-all duration-200"
						style="background: #FFFFFF; border: 3px solid var(--color-theme-border); box-shadow: 3px 3px 0px var(--color-theme-border); border-radius: 4px; color: var(--color-theme-text);"
					/>
				</div>

				<p
					id="error-msg"
					class="text-xs font-semibold hidden text-center"
					style="color: #C0392B;"
				>
				</p>

				<button
					type="submit"
					class="w-full font-display font-bold text-sm py-3.5 transition-all duration-100 active:translate-y-1 active:shadow-none mt-2"
					style="background: var(--color-primary); color: #FFF; border: 3px solid var(--color-theme-border); box-shadow: 4px 4px 0px var(--color-theme-border); border-radius: 4px;"
				>
					Entrar al Sistema
				</button>
			</form>
		</div>
	</main>
</Layout>

<script>
	import { apiClient } from "../utils/apiClient";

	const form = document.getElementById("login-form");
	const errorMsg = document.getElementById("error-msg");

	form?.addEventListener("submit", async (e) => {
		e.preventDefault();
		const username = (
			document.getElementById("username") as HTMLInputElement
		).value;
		const password = (
			document.getElementById("password") as HTMLInputElement
		).value;

		if (errorMsg) errorMsg.classList.add("hidden");

		try {
			await apiClient("/auth/login", {
				method: "POST",
				body: JSON.stringify({ username, password }),
			});
			window.location.href = "/dashboard";
		} catch {
			if (errorMsg) {
				errorMsg.textContent = "Usuario o contraseña incorrectos";
				errorMsg.classList.remove("hidden");
			}
		}
	});
</script>
