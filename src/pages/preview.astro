---
// Ruta temporal de PREVIEW sin autenticación — SOLO para desarrollo
import Layout from "../layouts/Layout.astro";
import ProductButton from "../components/ProductButton.astro";
import BottomNav from "../components/BottomNav.astro";

const totalVentas = 0;
const ultimasVentas: any[] = [];
---

<Layout title="Preview Dashboard — Acid Berry Lab POS">
    <!-- ══ HEADER ══ -->
    <header
        class="sticky top-0 z-40 px-5 pt-10 pb-5"
        style="background: var(--color-cream, #F5F0E8);"
    >
        <div class="flex items-center justify-between mb-3">
            <div>
                <p
                    class="text-[10px] font-semibold tracking-[0.2em] uppercase"
                    style="color: var(--color-gold);"
                >
                    Acid Berry Lab
                </p>
                <h1
                    class="font-display text-2xl font-bold leading-tight"
                    style="color: var(--color-burgundy);"
                >
                    Punto de Venta
                </h1>
            </div>
            <div
                class="w-12 h-12 rounded-full flex items-center justify-center text-xl"
                style="background: color-mix(in srgb, var(--color-burgundy) 10%, transparent); border: 1.5px solid color-mix(in srgb, var(--color-burgundy) 25%, transparent);"
            >
                🍋
            </div>
        </div>
        <div class="divider-gold"></div>

        <div
            class="mt-3 rounded-2xl px-5 py-4 flex items-center justify-between"
            style="background: var(--color-burgundy); box-shadow: 0 4px 20px color-mix(in srgb, var(--color-burgundy) 30%, transparent);"
        >
            <div>
                <p
                    class="text-[11px] font-medium tracking-widest uppercase opacity-70"
                    style="color: #FDFAF4;"
                >
                    Ventas de hoy
                </p>
                <h2
                    class="font-display text-4xl font-bold mt-0.5"
                    id="total-ventas-display"
                    style="color: #FDFAF4;"
                >
                    <span class="text-xl font-body font-medium">$</span><span
                        id="total-monto">{totalVentas.toFixed(2)}</span
                    >
                </h2>
            </div>
            <div class="text-right">
                <span
                    class="text-[11px] font-medium px-2 py-1 rounded-full"
                    id="ventas-count"
                    style="background: color-mix(in srgb, #FDFAF4 15%, transparent); color: #FDFAF4;"
                >
                    {ultimasVentas.length} ventas
                </span>
            </div>
        </div>
    </header>

    <main class="flex-1 px-4 pb-28">
        <section class="mb-8 mt-4">
            <div class="flex items-center gap-2 mb-4">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="w-4 h-4"
                    style="color: var(--color-gold);"
                >
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"
                    ></polygon>
                </svg>
                <h2
                    class="font-display text-base font-bold uppercase tracking-wide"
                    style="color: var(--color-theme-text);"
                >
                    Venta Rápida
                </h2>
            </div>

            <div class="mb-5">
                <p
                    class="text-[10px] font-semibold tracking-[0.15em] uppercase mb-2 pl-1"
                    style="color: var(--color-gold);"
                >
                    🍋 Limonadas Naturales
                </p>
                <div class="grid grid-cols-2 gap-3">
                    <ProductButton
                        title="Natural"
                        subtitle="Medio Litro · 500ml"
                        price={25}
                        variant="natural"
                    />
                    <ProductButton
                        title="Natural"
                        subtitle="Litro · 1L"
                        price={45}
                        variant="natural"
                    />
                </div>
            </div>

            <div class="mb-5">
                <p
                    class="text-[10px] font-semibold tracking-[0.15em] uppercase mb-2 pl-1"
                    style="color: var(--color-gold);"
                >
                    💧 Limonadas Minerales
                </p>
                <div class="grid grid-cols-2 gap-3">
                    <ProductButton
                        title="Mineral"
                        subtitle="Medio Litro · 500ml"
                        price={35}
                        variant="mineral"
                    />
                    <ProductButton
                        title="Mineral"
                        subtitle="Litro · 1L"
                        price={65}
                        variant="mineral"
                    />
                </div>
            </div>

            <div class="mb-5">
                <p
                    class="text-[10px] font-semibold tracking-[0.15em] uppercase mb-2 pl-1"
                    style="color: var(--color-gold);"
                >
                    🌿 Infusiones Botánicas
                </p>
                <div class="grid grid-cols-2 gap-3">
                    <ProductButton
                        title="Té Negro"
                        subtitle="con Limonada"
                        price={20}
                        variant="te-negro"
                    />
                    <ProductButton
                        title="Té Frutos"
                        subtitle="con Limonada"
                        price={30}
                        variant="te-frutos"
                    />
                </div>
            </div>

            <div class="mb-2">
                <p
                    class="text-[10px] font-semibold tracking-[0.15em] uppercase mb-2 pl-1"
                    style="color: var(--color-gold);"
                >
                    🍊 Clásica
                </p>
                <div class="grid grid-cols-2 gap-3">
                    <ProductButton
                        title="Clásica"
                        subtitle="Medio Litro · 500ml"
                        price={18}
                        variant="clasica"
                    />
                    <ProductButton
                        title="Clásica"
                        subtitle="Litro · 1L"
                        price={33}
                        variant="clasica"
                    />
                </div>
            </div>
        </section>

        <div class="divider-gold mb-6"></div>

        <section>
            <div class="flex items-center gap-2 mb-4">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="w-4 h-4"
                    style="color: var(--color-gold);"
                >
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"
                    ></rect><line x1="16" y1="2" x2="16" y2="6"></line><line
                        x1="8"
                        y1="2"
                        x2="8"
                        y2="6"></line><line x1="3" y1="10" x2="21" y2="10"
                    ></line>
                </svg>
                <h2
                    class="font-display text-base font-bold uppercase tracking-wide"
                    style="color: var(--color-theme-text);"
                >
                    Registro de Hoy
                </h2>
            </div>
            <div
                class="text-center py-10"
                style="background: var(--color-theme-surface); border-radius: 14px; border: 1.5px dashed color-mix(in srgb, var(--color-burgundy) 25%, transparent);"
            >
                <p class="text-3xl mb-2">🍋</p>
                <p
                    class="text-sm font-medium"
                    style="color: var(--color-theme-muted);"
                >
                    Aún no hay ventas registradas hoy.
                </p>
            </div>
        </section>
    </main>

    <BottomNav />
</Layout>
